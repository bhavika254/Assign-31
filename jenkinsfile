pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/bhavika254/Assign-31.git'
            }
        }

        stage('Install') {
            steps {
                bat 'npm install'
            }
        }

        stage('Build') {
            steps {
                bat 'npm run build'
            }
        }

        stage('Test') {
            steps {
                bat 'npm test'
            }
        }
    }
}